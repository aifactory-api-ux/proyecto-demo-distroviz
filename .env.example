# DistroViz Environment Configuration
# Copy this file to .env and configure as needed

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# SQLite database file path
DATABASE_URL=sqlite:///./distroviz.db

# ===========================================
# REDIS CONFIGURATION
# ===========================================
# Redis server hostname (use service name in Docker)
REDIS_HOST=redis

# Redis server port
REDIS_PORT=6379

# Redis database number (0-15)
REDIS_DB=0

# Redis password (leave empty if not required)
# REDIS_PASSWORD=

# Redis connection timeout in seconds
REDIS_TIMEOUT=5

# ===========================================
# CACHE CONFIGURATION
# ===========================================
# Cache TTL for metrics (in seconds)
# Default: 300 seconds (5 minutes)
CACHE_TTL_METRICS=300

# Cache TTL for trends (in seconds)
# Default: 600 seconds (10 minutes)
CACHE_TTL_TRENDS=600

# ===========================================
# FRONTEND CONFIGURATION
# ===========================================
# API URL for frontend (use service name in Docker)
VITE_API_URL=http://backend:8000

# ===========================================
# APPLICATION SETTINGS
# ===========================================
# CORS allowed origins (comma-separated)
# CORS_ORIGINS=*
